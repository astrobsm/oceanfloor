# ---- Shared ----
ENVIRONMENT=development

# ---- Database ----
# Option A (recommended for hosted DB e.g. Supabase / Neon / Vercel Postgres):
#   set a single DATABASE_URL. Both `postgres://` and `postgresql://`
#   schemes are accepted and rewritten to the SQLAlchemy psycopg2 driver.
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# Option B (local docker compose): use the individual fields below.
POSTGRES_USER=oceanfloor
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=oceanfloor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=8000
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated explicit origins (exact match):
CORS_ORIGINS=http://localhost:5173
# Optional regex for dynamic origins such as Vercel preview deployments:
# CORS_ORIGIN_REGEX=^https://oceanfloor.*\.vercel\.app$

# URL the backend uses to reach the statistical microservice
STATISTICAL_SERVICE_URL=http://statistical-service:8001

# ---- AI provider (agent layer) ----
# One of: openai | azure | anthropic | mock
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- External literature providers (no key required for these public APIs) ----
# Contact email is required by NCBI E-utilities and Crossref polite pool etiquette.
LITERATURE_CONTACT_EMAIL=research@example.org
NCBI_API_KEY=

# ---- Statistical service ----
STAT_SERVICE_PORT=8001

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
